{
  "title": "接口巡检监控面板",
  "uid": "healthcheck-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "巡检总次数",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "healthcheck_total",
          "legendFormat": "总次数"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 2,
      "title": "错误次数",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "healthcheck_errors_total",
          "legendFormat": "错误次数"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "成功率 (%)",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "(1 - healthcheck_errors_total / healthcheck_total) * 100",
          "legendFormat": "成功率"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizValue": 0,
        "maxVizValue": 100,
        "thresholds": {
          "steps": [
            { "color": "red",    "value": null },
            { "color": "yellow", "value": 80 },
            { "color": "green",  "value": 95 }
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "平均响应时间 (ms)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "healthcheck_duration_ms_avg",
          "legendFormat": "平均耗时"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 5,
      "title": "各接口响应时间趋势",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "healthcheck_duration_ms{job=\"healthcheck-app\"}",
          "legendFormat": "{{url}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 6,
      "title": "每分钟巡检次数",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(healthcheck_total[1m]) * 60",
          "legendFormat": "巡检频率"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "短/min", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 7,
      "title": "错误率趋势",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(healthcheck_errors_total[5m]) / rate(healthcheck_total[5m]) * 100",
          "legendFormat": "错误率 %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 5 }
            ]
          }
        }
      }
    }
  ]
}
