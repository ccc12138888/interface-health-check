# ─── 数据库配置 ───────────────────────────────────────────
DB_USER=root
DB_PASSWORD=root
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=healthcheck

# ─── 巡检配置 ─────────────────────────────────────────────
# cron 表达式（支持秒级，示例：每分钟执行一次）
CRON_SPEC=@every 1m
# 协程池大小
MAX_WORKER=5

# ─── Grafana ──────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
